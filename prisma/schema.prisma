generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@map("coupon_usages")
}

model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  discountType String
  value        Float
  minOrder     Float?
  expiry       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  maxDiscount  Float?
  perUserLimit Int?
  usageLimit   Int?
  usedCount    Int       @default(0)

  @@map("coupons")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "loyalty_transactions_userId_fkey")
  @@map("loyalty_transactions")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  variant   String? @db.LongText
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  total             Float
  status            String      @default("pending")
  paymentMethod     String
  razorpayOrderId   String?
  razorpayPaymentId String?
  name              String
  phone             String
  address           String
  city              String
  state             String
  pincode           String
  couponCode        String?
  discount          Float       @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  email             String?
  orderItems        OrderItem[]
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "orders_userId_fkey")
  @@map("orders")
}

model Product {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique
  description         String?
  images              String      @db.LongText
  categoryId          String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  isFeatured          Boolean     @default(false)
  isTodayOffer        Boolean     @default(false)
  isVisible           Boolean     @default(true)
  faqs                String?     @db.LongText
  ingredients         String?
  productOverview     String?
  seoKeywords         String?
  shippingInfo        String?
  storageInstructions String?
  whyChoose           String?
  benefits            String?
  nutritionalInfo     String?
  origin              String?
  shelfLife           String?
  shortDescription    String?
  pricePerKg          Float?
  stockGrams          Int         @default(0)
  orderItems          OrderItem[]
  category            Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reviews             Review[]
  wishlists           Wishlist[]

  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model Referral {
  id                                   String   @id @default(cuid())
  referrerId                           String
  referredPhone                        String
  status                               String   @default("pending")
  pointsAwarded                        Boolean  @default(false)
  createdAt                            DateTime @default(now())
  users_referrals_referredPhoneTousers User     @relation("referrals_referredPhoneTousers", fields: [referredPhone], references: [phone])
  users_referrals_referrerIdTousers    User     @relation("referrals_referrerIdTousers", fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredPhone])
  @@index([referredPhone], map: "referrals_referredPhone_fkey")
  @@map("referrals")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  name      String
  phone     String
  rating    Int      @default(5)
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "reviews_productId_fkey")
  @@map("reviews")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

model SiteVisit {
  id    String   @id @default(cuid())
  date  DateTime @default(now())
  count Int      @default(0)

  @@map("site_visits")
}

model User {
  id                String               @id @default(cuid())
  phone             String               @unique
  name              String?
  email             String?
  password          String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  loyaltyPoints     Int                  @default(0)
  referralCode      String?              @unique
  referredBy        String?
  firstPurchase     Boolean              @default(false)
  lastLoginDate     DateTime?
  securityAnswer    String?
  securityQuestion  String?
  addressBook       String?              @db.LongText
  pointTransactions LoyaltyTransaction[]
  orders            Order[]
  referralsReceived Referral[]           @relation("referrals_referredPhoneTousers")
  referralsMade     Referral[]           @relation("referrals_referrerIdTousers")
  wishlists         Wishlist[]

  @@map("users")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "wishlists_productId_fkey")
  @@map("wishlists")
}
