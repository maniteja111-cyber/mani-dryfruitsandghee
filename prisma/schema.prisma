generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String?
  createdAt DateTime @default(now())

  @@unique([couponId, userId, orderId])
  @@map("coupon_usages")
}

model Coupon {
  id           String    @id @default(cuid())
  code         String    @unique
  discountType String
  value        Float
  minOrder     Float?
  expiry       DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  maxDiscount  Float?
  perUserLimit Int?
  usageLimit   Int?
  usedCount    Int       @default(0)

  @@map("coupons")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "loyalty_transactions_userId_fkey")
  @@map("loyalty_transactions")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  variant   String? @db.LongText
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model Order {
  id                String      @id @default(cuid())
  userId            String
  total             Float
  status            String      @default("pending")
  paymentMethod     String
  razorpayOrderId   String?
  razorpayPaymentId String?
  name              String
  phone             String
  address           String
  city              String
  state             String
  pincode           String
  couponCode        String?
  discount          Float       @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  email             String?
  orderItems        OrderItem[]
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "orders_userId_fkey")
  @@map("orders")
}

model Product {
  id                      String                   @id @default(cuid())
  name                    String
  slug                    String                   @unique
  description             String?
  images                  String                   @db.LongText
  categoryId              String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  isFeatured              Boolean                  @default(false)
  isTodayOffer            Boolean                  @default(false)
  isVisible               Boolean                  @default(true)
  faqs                    String?                  @db.LongText
  ingredients             String?
  productOverview         String?
  seoKeywords             String?
  shippingInfo            String?
  storageInstructions     String?
  whyChoose               String?
  benefits                String?
  nutritionalInfo         String?
  origin                  String?
  shelfLife               String?
  shortDescription        String?
  pricePerKg              Float?
  stockGrams              Int                      @default(0)
  orderItems              OrderItem[]
  category                Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  reviews                 Review[]
  wishlists               Wishlist[]
  extension               ProductExtension?
  productVariants         ProductProductVariant[]
  giftBoxEligibleProducts GiftBoxEligibleProduct[]

  @@index([categoryId], map: "products_categoryId_fkey")
  @@map("products")
}

model Referral {
  id                                   String   @id @default(cuid())
  referrerId                           String
  referredPhone                        String
  status                               String   @default("pending")
  pointsAwarded                        Boolean  @default(false)
  createdAt                            DateTime @default(now())
  users_referrals_referredPhoneTousers User     @relation("referrals_referredPhoneTousers", fields: [referredPhone], references: [phone])
  users_referrals_referrerIdTousers    User     @relation("referrals_referrerIdTousers", fields: [referrerId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredPhone])
  @@index([referredPhone], map: "referrals_referredPhone_fkey")
  @@map("referrals")
}

model Review {
  id        String   @id @default(cuid())
  productId String
  name      String
  phone     String
  rating    Int      @default(5)
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "reviews_productId_fkey")
  @@map("reviews")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("settings")
}

model SiteVisit {
  id    String   @id @default(cuid())
  date  DateTime @default(now())
  count Int      @default(0)

  @@map("site_visits")
}

model User {
  id                String               @id @default(cuid())
  phone             String               @unique
  name              String?
  email             String?
  password          String?
  address           String?
  city              String?
  state             String?
  pincode           String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  loyaltyPoints     Int                  @default(0)
  referralCode      String?              @unique
  referredBy        String?
  firstPurchase     Boolean              @default(false)
  lastLoginDate     DateTime?
  securityAnswer    String?
  securityQuestion  String?
  addressBook       String?              @db.LongText
  pointTransactions LoyaltyTransaction[]
  orders            Order[]
  referralsReceived Referral[]           @relation("referrals_referredPhoneTousers")
  referralsMade     Referral[]           @relation("referrals_referrerIdTousers")
  wishlists         Wishlist[]

  @@map("users")
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId], map: "wishlists_productId_fkey")
  @@map("wishlists")
}

model MasterUnit {
  id         String             @id @default(cuid())
  code       String             @unique
  name       String
  type       String
  symbol     String?
  sortOrder  Int                @default(0)
  isActive   Boolean            @default(true)
  variants   MasterVariant[]
  extensions ProductExtension[]

  @@map("master_units")
}

model MasterVariant {
  id           String                  @id @default(cuid())
  unitId       String
  value        String
  label        String
  sortOrder    Int                     @default(0)
  isActive     Boolean                 @default(true)
  unit         MasterUnit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  products     ProductProductVariant[]
  pricingRules PricingRule[]

  @@unique([unitId, value])
  @@map("master_variants")
}

model PricingTemplate {
  id           String             @id @default(cuid())
  name         String
  slug         String             @unique
  description  String?
  isActive     Boolean            @default(true)
  sortOrder    Int                @default(0)
  isDefault    Boolean            @default(false)
  rules        String?            @db.LongText
  extensions   ProductExtension[]
  pricingRules PricingRule[]

  @@map("pricing_templates")
}

model PricingRule {
  id         String          @id @default(cuid())
  templateId String
  variantId  String
  percentage Float
  sortOrder  Int             @default(0)
  template   PricingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  variant    MasterVariant   @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([templateId, variantId])
  @@map("pricing_rules")
}

model ProductExtension {
  id                String           @id @default(cuid())
  productId         String           @unique
  unitTypeId        String?
  basePrice         Float?
  pricingTemplateId String?
  stockQuantity     Int              @default(0)
  product           Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  masterUnit        MasterUnit?      @relation(fields: [unitTypeId], references: [id])
  pricingTemplate   PricingTemplate? @relation(fields: [pricingTemplateId], references: [id])

  @@map("product_extensions")
}

model ProductProductVariant {
  id        String        @id @default(cuid())
  productId String
  variantId String
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   MasterVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, variantId])
  @@map("product_product_variants")
}

model GiftBox {
  id                   String                      @id @default(cuid())
  name                 String
  slug                 String                      @unique
  description          String?
  heroImage            String?
  thumbnail            String?
  gallery              String?
  seoTitle             String?
  seoDescription       String?
  seoKeywords          String?
  metaImage            String?
  ogTitle              String?
  ogDescription        String?
  ogImage              String?
  fixedPrice           Float
  originalPrice        Float?
  discount             Int                         @default(0)
  offerPrice           Float?
  gstRate              Float                       @default(18)
  packagingCharge      Float                       @default(0)
  deliveryCharge       Float                       @default(0)
  isActive             Boolean                     @default(true)
  isFeatured           Boolean                     @default(false)
  isTodayOffer         Boolean                     @default(false)
  sortOrder            Int                         @default(0)
  startDate            DateTime?
  endDate              DateTime?
  maxOrdersPerCustomer Int                         @default(0)
  minQuantity          Int                         @default(1)
  maxQuantity          Int?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  eligibleProducts     GiftBoxEligibleProduct[]
  rules                GiftBoxRule[]
  orders               GiftBoxOrder[]
  savedConfigurations  GiftBoxSavedConfiguration[]
  analytics            GiftBoxAnalytics[]

  @@map("gift_boxes")
}

model GiftBoxEligibleProduct {
  id           String  @id @default(cuid())
  giftBoxId    String
  productId    String
  sortOrder    Int     @default(0)
  price        Float?
  pricePerUnit String?
  giftBox      GiftBox @relation(fields: [giftBoxId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([giftBoxId, productId])
  @@map("gift_box_eligible_products")
}

model GiftBoxRule {
  id          String  @id @default(cuid())
  giftBoxId   String
  ruleType    String
  ruleValue   String  @db.LongText
  description String?
  giftBox     GiftBox @relation(fields: [giftBoxId], references: [id], onDelete: Cascade)

  @@map("gift_box_rules")
}

model GiftBoxOrder {
  id              String   @id @default(cuid())
  giftBoxId       String
  userId          String?
  userName        String
  userPhone       String
  userEmail       String?
  items           String   @db.LongText
  totalWeight     Float
  totalPrice      Float
  discount        Float    @default(0)
  GST             Float
  packagingCharge Float    @default(0)
  deliveryCharge  Float    @default(0)
  finalTotal      Float
  address         String?
  city            String?
  state           String?
  pincode         String?
  notes           String?
  giftWrap        Boolean  @default(false)
  ribbonColor     String?
  greetingCard    Boolean  @default(false)
  giftMessage     String?
  theme           String?
  paymentMethod   String   @default("cod")
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  giftBox         GiftBox  @relation(fields: [giftBoxId], references: [id], onDelete: Cascade)

  @@map("gift_box_orders")
}

model GiftBoxSavedConfiguration {
  id          String   @id @default(cuid())
  giftBoxId   String
  userId      String?
  guestId     String?
  name        String
  items       String   @db.LongText
  totalWeight Float
  totalPrice  Float
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  giftBox     GiftBox  @relation(fields: [giftBoxId], references: [id], onDelete: Cascade)

  @@map("gift_box_saved_configurations")
}

model GiftBoxAnalytics {
  id              String   @id @default(cuid())
  giftBoxId       String
  date            DateTime @default(now())
  ordersCount     Int      @default(0)
  totalRevenue    Float    @default(0)
  avgOrderValue   Float    @default(0)
  popularProducts String   @db.LongText
  createdAt       DateTime @default(now())
  giftBox         GiftBox  @relation(fields: [giftBoxId], references: [id], onDelete: Cascade)

  @@map("gift_box_analytics")
}
